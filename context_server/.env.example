# --- Obsidian backend (obsidian-local-rest-api) ---
OBSIDIAN_REST_API_KEY=paste-your-key-here
OBSIDIAN_HTTPS_URL=https://127.0.0.1:27124
OBSIDIAN_HTTP_URL=http://127.0.0.1:27123
# Trust the plugin's self-signed cert instead of disabling verification globally.
# Export it from the plugin (or fetch /obsidian-local-rest-api.crt) and point here:
OBSIDIAN_CERT_PATH=./obsidian-local-rest-api.crt
# Dev-only: allow falling back to plain HTTP 27123 if HTTPS cert can't be trusted.
ALLOW_HTTP_FALLBACK=true

# --- Context Server ---
CONTEXT_SERVER_HOST=127.0.0.1
CONTEXT_SERVER_PORT=27180
HOOKS_DIR=../hooks
IDENTITY_SECRET=paste-random-secret-here
ENABLE_WATCHER=true

# --- Observability (Langfuse) ---
# Enable LLM + agent-level tracing via Langfuse (Gap 3.3).
# When disabled, only OTel/Jaeger traces fire.
ENABLE_LANGFUSE=false
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# Self-hosted Langfuse on port 3001 (or cloud: https://cloud.langfuse.com)
LANGFUSE_HOST=http://localhost:3001

# --- Secrets Bridge (Gap 1.3 / Phase 2.7) ---
# Service credentials loaded from env vars with prefix SECRETS_<SERVICE>_KEY
# Each service auto-rotates after its TTL; agents call request_credentials for ephemeral tokens
SECRETS_OBSIDIAN_KEY=paste-your-obsidian-key
SECRETS_GITHUB_KEY=ghp_your-github-token
# Override defaults (seconds):
# SECRETS_OBSIDIAN_TTL=3600
# SECRETS_OBSIDIAN_ROTATION_TTL=86400
ENABLE_SECRETS_ROTATION=true
